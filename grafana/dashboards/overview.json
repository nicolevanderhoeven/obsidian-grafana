      "id": 23,
      "options": {
        "editor": {
          "format": "auto",
          "height": 600
        },
        "getOption": "// Transform Prometheus data to ECharts wordcloud format\nconst words = [];\n\n// Process data from Prometheus query\nif (data.series && data.series.length > 0) {\n  data.series.forEach(series => {\n    const wordLabel = series.fields.find(f => f.labels && f.labels.word);\n    const valueField = series.fields.find(f => f.name === 'Value' || f.type === 'number');\n    \n    if (wordLabel && valueField && valueField.values && valueField.values.length > 0) {\n      const word = wordLabel.labels.word;\n      const value = valueField.values[valueField.values.length - 1];\n      if (word && value > 0) {\n        words.push({ name: word, value: value });\n      }\n    }\n  });\n}\n\n// Sort by value and take top 100\nwords.sort((a, b) => b.value - a.value);\nconst topWords = words.slice(0, 100);\n\n// ECharts wordcloud configuration\nreturn {\n  tooltip: {\n    show: true,\n    formatter: function(params) {\n      return params.name + ': ' + params.value + ' occurrences';\n    }\n  },\n  series: [{\n    type: 'wordCloud',\n    shape: 'circle',\n    keepAspect: false,\n    left: 'center',\n    top: 'center',\n    width: '90%',\n    height: '90%',\n    right: null,\n    bottom: null,\n    sizeRange: [14, 80],\n    rotationRange: [-45, 45],\n    rotationStep: 15,\n    gridSize: 8,\n    drawOutOfBound: false,\n    shrinkToFit: true,\n    layoutAnimation: true,\n    textStyle: {\n      fontFamily: 'sans-serif',\n      fontWeight: 'bold',\n      color: function() {\n        // Random color from a pleasing palette\n        const colors = [\n          '#5470c6', '#91cc75', '#fac858', '#ee6666', '#73c0de',\n          '#3ba272', '#fc8452', '#9a60b4', '#ea7ccc', '#48b8d0'\n        ];\n        return colors[Math.floor(Math.random() * colors.length)];\n      }\n    },\n    emphasis: {\n      focus: 'self',\n      textStyle: {\n        textShadowBlur: 10,\n        textShadowColor: '#333'\n      }\n    },\n    data: topWords\n  }]\n};",
        "renderer": "canvas",
        "themeEditor": {
          "config": "{}",
          "name": "default"
        }
      },
      "pluginVersion": "12.4.1",
