#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/../scripts" && pwd)"

if ! curl -sf "http://localhost:3000/api/health" &>/dev/null; then
  echo "[pre-commit] Grafana not running — skipping dashboard export."
  exit 0
fi

echo "[pre-commit] Exporting Grafana dashboards..."
"${SCRIPT_DIR}/export-dashboards.sh"

if git diff --name-only grafana/dashboards/ | grep -q .; then
  git add grafana/dashboards/*.json
  echo "[pre-commit] Dashboard changes staged."
fi
